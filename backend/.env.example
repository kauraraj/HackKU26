# Supabase — find these under Project Settings → API in your Supabase dashboard
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# AI provider — the extractor and planner default to OpenAI-compatible chat completions
OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-4o-mini

# Geocoding — defaults to Nominatim (free, no key); set MAPBOX_TOKEN if you want Mapbox fallback
MAPBOX_TOKEN=

# If MOCK_AI=1, extractor and planner return deterministic stubs (great for offline demos)
MOCK_AI=0

# Listen host/port (for docker-compose or remote dev). Leave defaults for local.
HOST=0.0.0.0
PORT=8000
