# Copy to .env.local. Expo exposes vars prefixed with EXPO_PUBLIC_ to the app.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Point to your FastAPI backend. On a physical device, use your machine's LAN IP, not localhost.
EXPO_PUBLIC_API_URL=http://localhost:8000
